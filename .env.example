# ==========================================
# Netlify Environment Variables
# ==========================================
# Add these variables in your Netlify Dashboard:
# Site settings > Environment variables

# Rupantor Pay API Key (Required for payment processing)
RUPANTOR_API_KEY=your_rupantor_api_key_here

# Your frontend domain (Without https://)
FRONTEND_DOMAIN=your_frontend_domain_here

# Formspree Endpoint URL
FORMSPREE_ENDPOINT=your_formspree_endpoint_here

# ==========================================
# Vite Environment Variables (Client-side)
# ==========================================
# These variables must start with VITE_ to be exposed to the browser

# Cloudinary Configuration
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset

# Formspree Endpoint URL (Client-side fallback)
VITE_FORMSPREE_ENDPOINT=your_formspree_endpoint_here

# Signature Image URL for PDF Receipts
VITE_SIGNATURE_URL=your_signature_image_url_here